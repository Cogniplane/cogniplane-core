{
  "name": "cogniplane-core",
  "private": true,
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "codex:release:check": "pnpm --filter @cogniplane/backend exec vitest run src/codex-release.test.ts",
    "codex:schema:generate": "node scripts/generate-codex-schemas.mjs",
    "dev": "node scripts/check-dev-ports.mjs && pnpm --parallel --filter @cogniplane/backend --filter @cogniplane/frontend dev",
    "lint": "eslint .",
    "test": "pnpm -r --if-present test",
    "test:all": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "pnpm --filter @cogniplane/backend exec vitest run --coverage",
    "test:e2e:local": "node scripts/e2e-local-stack.mjs",
    "typecheck": "pnpm -r typecheck",
    "db:migrate": "pnpm --filter @cogniplane/backend db:migrate",
    "license:check": "tsx scripts/license-check.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@next/eslint-plugin-next": "^16.2.6",
    "@types/node": "25.6.2",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "4.1.5",
    "dotenv": "^17.4.2",
    "e2b": "^2.19.5",
    "eslint": "10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "17.6.0",
    "husky": "^9.1.7",
    "ts-morph": "^28.0.0",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.2",
    "vitest": "4.1.5",
    "yaml": "^2.9.0"
  },
  "pnpm": {
    "overrides": {
      "fast-uri@<3.1.2": ">=3.1.2"
    }
  }
}
