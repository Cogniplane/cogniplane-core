API_HOST=0.0.0.0
API_PORT=3001
API_ORIGIN=http://localhost:3000
# app_user is the restricted role subject to RLS policies used at runtime.
# Its password is bootstrapped from DATABASE_URL during migrations — no need
# to create the role manually. The password in DATABASE_URL must match what
# the operator wants; migration will call ALTER ROLE app_user WITH PASSWORD.
DATABASE_URL=postgres://app_user:app_user_password@localhost:5432/cogniplane
LOCAL_DEV_USER_ID=local-dev-user
CODEX_BINARY_PATH=codex
CODEX_MODEL=gpt-5.4-mini
RUNTIME_WORKSPACE_ROOT=/tmp/cogniplane-core-runtime-workspaces
RUNTIME_START_TIMEOUT_MS=20000
RUNTIME_REQUEST_TIMEOUT_MS=120000
# Public reviewed skills catalog shown in the admin Skills marketplace
# SKILL_MARKETPLACE_MANIFEST_URL=https://raw.githubusercontent.com/Cogniplane/agent-skills-marketplace/main/marketplace.json

# Auth — set to 'workos' for production SSO, 'dev-headers' for local dev
AUTH_MODE=dev-headers
# WORKOS_API_KEY=sk_test_...
# WORKOS_CLIENT_ID=client_...
# WORKOS_REDIRECT_URI=http://localhost:3000/auth/callback
# Required: superuser URL used by db:migrate to CREATE ROLE, set passwords, and enable RLS.
MIGRATION_DATABASE_URL=postgres://postgres:postgres@localhost:5432/cogniplane
JWT_SECRET=local-dev-jwt-secret-change-in-production!!

# Redis — required for WorkOS refresh-token revocation, optional in dev-headers mode
# REDIS_URL=redis://localhost:6379

# Model provider API keys — server-level fallback.
# In production, prefer per-tenant keys saved in admin → org settings (encrypted at
# rest, scopable per tenant). Runtime resolution is: tenant key → these env vars → null.
#
# ANTHROPIC_API_KEY enables the Claude runtime. The Claude Agent SDK requires an API
# key from console.anthropic.com — consumer subscriptions (Free/Pro/Max) are NOT
# supported. Use is governed by Anthropic's Commercial Terms of Service:
# https://www.anthropic.com/legal/commercial-terms
# Without it (and without a per-tenant key), only the Codex runtime is registered.
# ANTHROPIC_API_KEY=sk-ant-...
#
# OPENAI_API_KEY enables the Codex runtime when no per-tenant key is configured.
# OPENAI_API_KEY=sk-...

# Notion OAuth — register a public integration at https://www.notion.so/profile/integrations.
# All three are required together; if any is missing the integration is treated as not configured.
# NOTION_OAUTH_CLIENT_ID=
# NOTION_OAUTH_CLIENT_SECRET=
# NOTION_OAUTH_REDIRECT_URI=http://localhost:3001/integrations/notion/callback
